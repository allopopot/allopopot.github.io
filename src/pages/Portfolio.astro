---
import MainLayout from "../layouts/MainLayout.astro";
const title = "Portfolio";
import portfolioData from "../assets/portfolioData.json";
import Carousel from "../components/Carousel.vue";
import Footer from "../components/Footer.astro"
---

<MainLayout title={title}>
    <div class="w-full h-full overflow-auto">
        <div class="w-full sm:w-full md:w-2/3 lg:w-2/3 mx-auto mt-14 px-5">
            <h1
                class="text-3xl sm:text-3xl md:text-4xl lg:text-4xl font-semibold text-yellow-300 mb-4"
            >
                My Portfolio
            </h1>
            <hr class="my-4 border-yellow-300" />

            {
                portfolioData.map((el) => {
                    return (
                        <div class="border border-2 border-yellow-300 shadow-lg rounded-lg p-5 mb-4">
                            <h2 class="text-2xl font-semibold mb-4">
                                {el.title}
                            </h2>

                            {/* Carousel */}
                            {() => {
                                if (el.picturesPath.length !== 0) {
                                    return (
                                        <Carousel
                                            client:only="vue"
                                            images={el.picturesPath}
                                            class={"border-2 border-yellow-300"}
                                        />
                                    );
                                }
                            }}
                            {/* Carousel */}

                            <ul class="mt-5">
                                {el.description.map((ul) => {
                                    return (
                                        <li class="list-disc text-md ml-6">
                                            {ul}
                                        </li>
                                    );
                                })}
                            </ul>
                        </div>
                    );
                })
            }
        </div>
        <Footer></Footer>
    </div>
</MainLayout>
