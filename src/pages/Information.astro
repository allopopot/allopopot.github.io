---
import MainLayout from "../layouts/MainLayout.astro";
const title = "Information";
import { summary, technologiesAlternative, certifications } from "../assets/data.json";
import Footer from "../components/Footer.astro";
---

<MainLayout title={title}>
    <div class="w-full h-full overflow-auto">
        <div class="w-full sm:w-full md:w-2/3 lg:w-2/3 mx-auto mt-14 px-5">
            <h1 class="text-3xl sm:text-3xl md:text-4xl lg:text-4xl font-semibold text-yellow-300 mb-4">
                A Little bit about myself...
            </h1>
            <hr class="my-4 border-yellow-300" />
            {
                summary.map((el) => {
                    return <p class="text-lg mb-1 ">{el}</p>;
                })
            }

            <h1 class="text-3xl sm:text-3xl md:text-4xl lg:text-4xl font-semibold text-yellow-300 mb-4 mt-4">
                My Growing Skillset...
            </h1>
            <hr class="my-4 border-yellow-300" />

            <div class="text-center">
                {
                    technologiesAlternative.map((el) => {
                        return (
                            <p class="inline-block px-4 py-2 bg-gray-800 rounded-full mx-2 my-1 border-2 border-yellow-300 hover:text-gray-900 hover:bg-yellow-300 font-semibold select-none">
                                {el}
                            </p>
                        );
                    })
                }
            </div>

            <h1 class="text-3xl sm:text-3xl md:text-4xl lg:text-4xl font-semibold text-yellow-300 mb-4 mt-4">
                Some Certifications that I have Ascertained...
            </h1>
            <hr class="my-4 border-yellow-300" />
            {
                certifications.map((el) => {
                    return (
                        <a
                            class="hover:decoration-yellow-300 underline decoration-white-300 block mb-2 text-lg"
                            href={el.link}
                        >
                            <i class="inline-block">
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="16"
                                    height="16"
                                    fill="currentColor"
                                    class="bi bi-link-45deg"
                                    viewBox="0 0 16 16"
                                >
                                    <path d="M4.715 6.542 3.343 7.914a3 3 0 1 0 4.243 4.243l1.828-1.829A3 3 0 0 0 8.586 5.5L8 6.086a1 1 0 0 0-.154.199 2 2 0 0 1 .861 3.337L6.88 11.45a2 2 0 1 1-2.83-2.83l.793-.792a4 4 0 0 1-.128-1.287z" />
                                    <path d="M6.586 4.672A3 3 0 0 0 7.414 9.5l.775-.776a2 2 0 0 1-.896-3.346L9.12 3.55a2 2 0 1 1 2.83 2.83l-.793.792c.112.42.155.855.128 1.287l1.372-1.372a3 3 0 1 0-4.243-4.243z" />
                                </svg>
                            </i>
                            {el.title} ({el.acquired})
                        </a>
                    );
                })
            }
        </div>
        <Footer></Footer>
    </div>
</MainLayout>
